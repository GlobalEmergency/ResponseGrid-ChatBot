# OpenAI
OPENAI_API_KEY=sk-pon-tu-api-key
# Opcional. Si lo dejas vacío, el SDK usará su modelo por defecto.
OPENAI_MODEL=

# ResponseGrid API (compartida por todas las cuentas; las credenciales por cuenta viven en accounts.json)
API_BASE_URL=https://api.responsegrid.app

# WhatsApp Cloud API (solo si hay alguna cuenta channel=whatsapp en accounts.json)
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_PORT=8787

# Seguridad / observabilidad
OPENAI_AGENTS_TRACE_INCLUDE_SENSITIVE_DATA=false
