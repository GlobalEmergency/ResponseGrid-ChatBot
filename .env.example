# OpenAI
OPENAI_API_KEY=sk-pon-tu-api-key
# Opcional. Si lo dejas vacío, el SDK usará su modelo por defecto.
OPENAI_MODEL=

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AA-pon-tu-token-de-botfather

# ResponseGrid API
API_BASE_URL=https://api.responsegrid.app

# Autenticación contra ResponseGrid:
# - bearer: usa Authorization: Bearer <API_TOKEN>
# - api-key: usa X-API-Key: <API_TOKEN>
API_AUTH_MODE=api-key
API_TOKEN=pon-tu-jwt-o-api-key

# Emergencia por defecto para no tener que indicar emergencyId en cada mensaje.
# Usa una de estas dos opciones:
RESPONSEGRID_DEFAULT_EMERGENCY_ID=
RESPONSEGRID_DEFAULT_EMERGENCY_SLUG=terremoto-venezuela-2026

# Seguridad / observabilidad
# En pruebas con datos reales, mejor false para no incluir datos sensibles en trazas.
OPENAI_AGENTS_TRACE_INCLUDE_SENSITIVE_DATA=false

# Simulación de login por teléfono (en desarrollo/demo)
# Cuando el usuario comparta este teléfono en Telegram, el bot le asociará este JWT token de usuario.
# USER_PHONE=+34600000000
# USER_TOKEN=eyJhbGciOi...
